msgstr  "Uzvedne analizē sarežģītos vārdus un dod definīcijas, sinonīmus un piemērus."

#: ../assistant_prompts.lua:161
msgid   "Grammar"
msgstr  "Gramatika"

#: ../assistant_prompts.lua:164
