#: ../assistant_prompts.lua:30
msgid   "This prompt creates a structured system for generating context-aware definitions of words or phrases from literature by analyzing the highlighted term within its surrounding text to provide nuanced explanations that capture both literal meaning and contextual significance."
msgstr  "Este prompt cria um sistema estruturado para gerar definições contextuais de palavras ou frases da literatura, analisando o termo destacado em seu texto circundante para fornecer explicações nuances que capturam tanto o significado literal quanto a importância contextual."

#: ../assistant_prompts.lua:67
msgid   "This prompt acts as a dictionary for the highlighted text, to a word or phrase."
msgstr  "Este prompt funciona como um dicionário para o texto destacado, para uma palavra ou frase."

#: ../assistant_prompts.lua:73 ../assistant_quicknote.lua:101
msgid   "Quick Note"
msgstr  "Nota Rápida"

#: ../assistant_prompts.lua:74
msgid   "This button creates a quick note with highlighted text."
msgstr  "Este botão cria uma nota rápida com o texto destacado."

#: ../assistant_prompts.lua:79
msgid   "Vocabulary"
msgstr  "Vocabulário"

#: ../assistant_prompts.lua:83
msgid   "This prompt analyzes the vocabulary of the highlighted text, identifying complex words and providing definitions, synonyms, and usage examples."
msgstr  "Este prompt analisa o vocabulário do texto destacado, identificando palavras complexas e fornecendo definições, sinônimos e exemplos de uso."

#: ../assistant_prompts.lua:100
msgid   "Grammar"
msgstr  "Gramática"

#: ../assistant_prompts.lua:104
msgid   "This prompt analyzes the grammar of the highlighted text, providing a detailed explanation of its structure and any grammatical errors."
msgstr  "Este prompt analisa a gramática do texto destacado, fornecendo uma explicação detalhada de sua estrutura e quaisquer erros gramaticais."

#: ../assistant_prompts.lua:129
msgid   "Translate"
msgstr  "Traduzir"

#: ../assistant_prompts.lua:131
msgid   "This prompt translates the highlighted text to another language."
msgstr  "Este prompt traduz o texto destacado para outro idioma."

#: ../assistant_prompts.lua:143
msgid   "Summarize"
msgstr  "Resumir"

#: ../assistant_prompts.lua:146
msgid   "This prompt summarizes the highlighted text, capturing its main points and essential details."
msgstr  "Este prompt resume o texto destacado, capturando seus pontos principais e detalhes essenciais."

#: ../assistant_prompts.lua:161
msgid   "Simplify"
msgstr  "Simplificar"

#: ../assistant_prompts.lua:164
msgid   "This prompt simplifies the highlighted text to make it easier to understand."
msgstr  "Este prompt simplifica o texto destacado para facilitar a compreensão."

#: ../assistant_prompts.lua:178
msgid   "Key Points"
msgstr  "Pontos-Chave"

#: ../assistant_prompts.lua:182
msgid   "This prompt extracts and lists the key points from the highlighted text, ensuring clarity and organization."
msgstr  "Este prompt extrai e lista os pontos-chave do texto destacado, garantindo clareza e organização."

#: ../assistant_prompts.lua:204
msgid   "ELI5"
msgstr  "ELI5"

#: ../assistant_prompts.lua:208
msgid   "This prompt explains the highlighted text as if to a five-year-old, simplifying complex concepts into easily understandable terms."
msgstr  "Este prompt explica o texto destacado como se para uma criança de cinco anos, simplificando conceitos complexos em termos facilmente compreensíveis."

#: ../assistant_prompts.lua:229
msgid   "🌐Explain"
msgstr  "🌐Explicar"

#: ../assistant_prompts.lua:232
msgid   "This prompt explains the highlighted text in detail, ensuring clarity and understanding."
msgstr  "Este prompt explica o texto destacado em detalhes, garantindo clareza e compreensão."

#: ../assistant_prompts.lua:246
msgid   "🌐Historical Context"
msgstr  "🌐Contexto Histórico"

#: ../assistant_prompts.lua:250
msgid   "This prompt provides a detailed historical context for the highlighted text, explaining its significance and background."
msgstr  "Este prompt fornece um contexto histórico detalhado para o texto destacado, explicando sua importância e origem."

#: ../assistant_prompts.lua:272
msgid   "🌐Wikipedia"
msgstr  "🌐Wikipédia"

#: ../assistant_prompts.lua:276
msgid   "This prompt generates a comprehensive Wikipedia-style article based on the highlighted text, ensuring factual accuracy and neutrality."
msgstr  "Este prompt gera um artigo completo no estilo da Wikipedia baseado no texto destacado, garantindo precisão factual e neutralidade."

