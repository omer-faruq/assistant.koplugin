#: ../assistant_prompts.lua:257
msgid   "Explain"
msgstr  "Explicar"

#: ../assistant_prompts.lua:259
msgid   "This prompt explains the highlighted text in detail, ensuring clarity and understanding."
msgstr  "Este prompt explica detalladamente o texto resaltado, garantindo claridade e comprensión."

#: ../assistant_prompts.lua:270
msgid   "Historical Context"
msgstr  "Contexto Histórico"

#: ../assistant_prompts.lua:273
msgid   "This prompt provides a detailed historical context for the highlighted text, explaining its significance and background."
msgstr  "Este prompt proporciona un contexto histórico detallado do texto resaltado, explicando súa importancia e fondo."

