#: ../assistant_prompts.lua:24
msgid   "This prompt creates a structured system for generating context-aware definitions of words or phrases from literature by analyzing the highlighted term within its surrounding text to provide nuanced explanations that capture both literal meaning and contextual significance."
msgstr  "Denne prompt skaber et struktureret system til at generere kontekstbevidste definitioner af ord eller vendinger fra litteratur ved at analysere den markerede term i dens omgivende tekst for at give nuancerede forklaringer, som både fanger den bogstavelige betydning og den kontekstuelle betydning."

#: ../assistant_prompts.lua:129
msgid   "This prompt acts as a dictionary for the highlighted text, to a word or phrase."
msgstr  "Dette prompt fungerer som en ordbog for den markerede tekst, til et ord eller en frase."

#: ../assistant_prompts.lua:135 ../assistant_quicknote.lua:101
msgid   "Quick Note"
msgstr  "Hurtig note"

#: ../assistant_prompts.lua:136
msgid   "This button creates a quick note with highlighted text."
msgstr  "Denne knap opretter en hurtig note med markeret tekst."

#: ../assistant_prompts.lua:141
msgid   "Vocabulary"
msgstr  "Ordforråd"

#: ../assistant_prompts.lua:144
msgid   "This prompt analyzes the vocabulary of the highlighted text, identifying complex words and providing definitions, synonyms, and usage examples."
msgstr  "Dette prompt analyserer ordforrådet i den markerede tekst, identificerer komplekse ord og giver definitioner, synonymer og brugseksempler."

#: ../assistant_prompts.lua:161
msgid   "Grammar"
msgstr  "Grammatik"

#: ../assistant_prompts.lua:164
msgid   "This prompt analyzes the grammar of the highlighted text, providing a detailed explanation of its structure and any grammatical errors."
msgstr  "Dette prompt analyserer grammatikken af den markerede tekst og giver en detaljeret forklaring af dens struktur og eventuelle grammatiske fejl."

#: ../assistant_prompts.lua:180
msgid   "Translate"
msgstr  "Oversæt"

#: ../assistant_prompts.lua:181
msgid   "This prompt translates the highlighted text to another language."
msgstr  "Dette prompt oversætter den markerede tekst til et andet sprog."

#: ../assistant_prompts.lua:202
msgid   "Summarize"
msgstr  "Opsummer"

#: ../assistant_prompts.lua:204
msgid   "This prompt summarizes the highlighted text, capturing its main points and essential details."
msgstr  "Dette prompt opsummerer den markerede tekst, fangende dens hovedpunkter og væsentlige detaljer."

#: ../assistant_prompts.lua:213
msgid   "Simplify"
msgstr  "Forenkle"

#: ../assistant_prompts.lua:215
msgid   "This prompt simplifies the highlighted text to make it easier to understand."
msgstr  "Dette prompt forenkler den markerede tekst for at gøre den lettere at forstå."

#: ../assistant_prompts.lua:226
msgid   "Key Points"
msgstr  "Nøglepunkter"

#: ../assistant_prompts.lua:229
msgid   "This prompt extracts and lists the key points from the highlighted text, ensuring clarity and organization."
msgstr  "Dette prompt udtrækker og lister nøglepunkterne fra den markerede tekst, med sikring af klarhed og organisering."

#: ../assistant_prompts.lua:241
msgid   "ELI5"
msgstr  "ELI5"

#: ../assistant_prompts.lua:244
msgid   "This prompt explains the highlighted text as if to a five-year-old, simplifying complex concepts into easily understandable terms."
msgstr  "Dette prompt forklarer den markerede tekst som om til en femårig, forenkler komplekse begreber til let forståelige termer."

#: ../assistant_prompts.lua:257
msgid   "Explain"
msgstr  "Forklar"

#: ../assistant_prompts.lua:259
msgid   "This prompt explains the highlighted text in detail, ensuring clarity and understanding."
msgstr  "Dette prompt forklarer den markerede tekst i detaljer, med sikring af klarhed og forståelse."

#: ../assistant_prompts.lua:270
msgid   "Historical Context"
msgstr  "Historisk kontekst"

#: ../assistant_prompts.lua:273
msgid   "This prompt provides a detailed historical context for the highlighted text, explaining its significance and background."
msgstr  "Dette prompt giver en detaljeret historisk kontekst for den markerede tekst, og forklarer dens betydning og baggrund."

#: ../assistant_prompts.lua:285 ../main.lua:816
msgid   "Wikipedia"
msgstr  "Wikipedia"

#: ../assistant_prompts.lua:288
msgid   "This prompt generates a comprehensive Wikipedia-style article based on the highlighted text, ensuring factual accuracy and neutrality."
msgstr  "Dette prompt genererer en omfattende Wikipedia-lignende artikel baseret på den markerede tekst, og sikrer fakta og neutralitet."

