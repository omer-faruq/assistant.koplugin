#: ../assistant_prompts.lua:24
msgid   "This prompt creates a structured system for generating context-aware definitions of words or phrases from literature by analyzing the highlighted term within its surrounding text to provide nuanced explanations that capture both literal meaning and contextual significance."
msgstr  "בקשה זו יוצרת מערכת מובנית ליצירת הגדרות מותאמות הקשר של מילים או ביטויים מתוך ספרות, על ידי ניתוח המונח המודגש בתוך הטקסט שסביבו כדי לספק הסברים מעודנים התופסים הן את המשמעות המילולית והן את החשיבות ההקשרית."

#: ../assistant_prompts.lua:129
msgid   "This prompt acts as a dictionary for the highlighted text, to a word or phrase."
msgstr  "הקוד הזה פועל כמילון לטקסט המודגש, למילה או ביטוי."

#: ../assistant_prompts.lua:135 ../assistant_quicknote.lua:101
msgid   "Quick Note"
msgstr  "הערה מהירה"

#: ../assistant_prompts.lua:136
msgid   "This button creates a quick note with highlighted text."
msgstr  "כפתור זה יוצר הערה מהירה עם הטקסט המודגש."

#: ../assistant_prompts.lua:141
msgid   "Vocabulary"
msgstr  "אוצר מילים"

#: ../assistant_prompts.lua:144
msgid   "This prompt analyzes the vocabulary of the highlighted text, identifying complex words and providing definitions, synonyms, and usage examples."
msgstr  "הקוד הזה מנתח את אוצר המילים של הטקסט המודגש, מזהה מילים מורכבות ומספק הגדרות, מילים נרדפות ודוגמאות שימוש."

#: ../assistant_prompts.lua:161
msgid   "Grammar"
msgstr  "דקדוק"

#: ../assistant_prompts.lua:164
msgid   "This prompt analyzes the grammar of the highlighted text, providing a detailed explanation of its structure and any grammatical errors."
msgstr  "הקוד הזה מנתח את הדקדוק של הטקסט המודגש, מספק הסבר מפורט של המבנה וכל שגיאה דקדוקית."

#: ../assistant_prompts.lua:180
msgid   "Translate"
msgstr  "העבר"

#: ../assistant_prompts.lua:181
msgid   "This prompt translates the highlighted text to another language."
msgstr  "הקוד הזה מעביר את הטקסט המודגש לשפה אחרת."

#: ../assistant_prompts.lua:202
msgid   "Summarize"
msgstr  "תקציר"

#: ../assistant_prompts.lua:204
msgid   "This prompt summarizes the highlighted text, capturing its main points and essential details."
msgstr  "הקוד הזה מסכם את הטקסט המודגש, כולל נקודות עיקריות ופרטים חשובים."

#: ../assistant_prompts.lua:213
msgid   "Simplify"
msgstr  "פשט"

#: ../assistant_prompts.lua:215
msgid   "This prompt simplifies the highlighted text to make it easier to understand."
msgstr  "הקוד הזה מפשט את הטקסט המודגש כדי להקל על ההבנה."

#: ../assistant_prompts.lua:226
msgid   "Key Points"
msgstr  "נקודות מפתח"

#: ../assistant_prompts.lua:229
msgid   "This prompt extracts and lists the key points from the highlighted text, ensuring clarity and organization."
msgstr  "הקוד הזה מציין ומפרט את נקודות המפתח מתוך הטקסט המודגש, תוך הבטחת בהירות והארגון."

#: ../assistant_prompts.lua:241
msgid   "ELI5"
msgstr  "הסבר ל-5 שנים"

#: ../assistant_prompts.lua:244
msgid   "This prompt explains the highlighted text as if to a five-year-old, simplifying complex concepts into easily understandable terms."
msgstr  "הקוד הזה מסביר את הטקסט המודגש כאילו הוא נכתב לילד בן חמישה, מפשט מושגים מורכבים למונחים מובנים."

#: ../assistant_prompts.lua:257
msgid   "Explain"
msgstr  "הסבר"

#: ../assistant_prompts.lua:259
msgid   "This prompt explains the highlighted text in detail, ensuring clarity and understanding."
msgstr  "הקוד הזה מסביר את הטקסט המודגש במפורט, תוך הבטחת בהירות והבנה."

#: ../assistant_prompts.lua:270
msgid   "Historical Context"
msgstr  "הקשר היסטורי"

#: ../assistant_prompts.lua:273
msgid   "This prompt provides a detailed historical context for the highlighted text, explaining its significance and background."
msgstr  "הקוד הזה מספק הקשר היסטורי מפורט לטקסט המודגש, עם הסבר על חשיבותו והרקע שלו."

