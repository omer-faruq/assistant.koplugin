#: ../assistant_prompts.lua:24
msgid   "This prompt creates a structured system for generating context-aware definitions of words or phrases from literature by analyzing the highlighted term within its surrounding text to provide nuanced explanations that capture both literal meaning and contextual significance."
msgstr  "Dieser Prompt erstellt ein strukturiertes System zur Erzeugung kontextbezogener Definitionen von Wörtern oder Ausdrücken aus Literatur, indem der markierte Begriff im umgebenden Text analysiert wird, um nuancierte Erklärungen zu liefern, sowohl wörtliche Bedeutung als auch kontextuelle Bedeutung erfassen."

#: ../assistant_prompts.lua:129
msgid   "This prompt acts as a dictionary for the highlighted text, to a word or phrase."
msgstr  "Dieser Prompt fungiert als Wörterbuch für den hervorgehobenen Text, zu einem Wort oder Ausdruck."

#: ../assistant_prompts.lua:135 ../assistant_quicknote.lua:101
msgid   "Quick Note"
msgstr  "Schnelle Notiz"

#: ../assistant_prompts.lua:136
msgid   "This button creates a quick note with highlighted text."
msgstr  "Diese Schaltfläche erstellt eine schnelle Notiz mit markiertem Text."

#: ../assistant_prompts.lua:141
msgid   "Vocabulary"
msgstr  "Vokabular"

#: ../assistant_prompts.lua:144
msgid   "This prompt analyzes the vocabulary of the highlighted text, identifying complex words and providing definitions, synonyms, and usage examples."
msgstr  "Dieser Prompt analysiert das Vokabular des hervorgehobenen Textes, identifiziert komplexe Wörter und liefert Definitionen, Synonyme und Anwendungsbeispiele."

#: ../assistant_prompts.lua:161
msgid   "Grammar"
msgstr  "Grammatik"

#: ../assistant_prompts.lua:164
msgid   "This prompt analyzes the grammar of the highlighted text, providing a detailed explanation of its structure and any grammatical errors."
msgstr  "Dieser Prompt analysiert die Grammatik des hervorgehobenen Textes und liefert eine detaillierte Erklärung seiner Struktur und möglicher Grammatikfehler."

#: ../assistant_prompts.lua:180
msgid   "Translate"
msgstr  "Übersetzen"

#: ../assistant_prompts.lua:181
msgid   "This prompt translates the highlighted text to another language."
msgstr  "Dieser Prompt übersetzt den hervorgehobenen Text in eine andere Sprache."

#: ../assistant_prompts.lua:202
msgid   "Summarize"
msgstr  "Zusammenfassen"

#: ../assistant_prompts.lua:204
msgid   "This prompt summarizes the highlighted text, capturing its main points and essential details."
msgstr  "Dieser Prompt fasst den hervorgehobenen Text zusammen, indem er seine Hauptpunkte und wesentlichen Details erfasst."

#: ../assistant_prompts.lua:213
msgid   "Simplify"
msgstr  "Vereinfachen"

#: ../assistant_prompts.lua:215
msgid   "This prompt simplifies the highlighted text to make it easier to understand."
msgstr  "Dieser Prompt vereinfacht den hervorgehobenen Text, um ihn leichter verständlich zu machen."

#: ../assistant_prompts.lua:226
msgid   "Key Points"
msgstr  "Schlüsselpunkte"

#: ../assistant_prompts.lua:229
msgid   "This prompt extracts and lists the key points from the highlighted text, ensuring clarity and organization."
msgstr  "Dieser Prompt extrahiert und listet die Schlüsselpunkte des hervorgehobenen Textes auf, um Klarheit und Organisation sicherzustellen."

#: ../assistant_prompts.lua:241
msgid   "ELI5"
msgstr  "ELI5"

#: ../assistant_prompts.lua:244
msgid   "This prompt explains the highlighted text as if to a five-year-old, simplifying complex concepts into easily understandable terms."
msgstr  "Dieser Prompt erklärt den hervorgehobenen Text so, als wäre er einem fünfjährigen Kind erklärt, und vereinfacht komplexe Konzepte in leicht verständliche Begriffe."

#: ../assistant_prompts.lua:257
msgid   "Explain"
msgstr  "Erklären"

#: ../assistant_prompts.lua:259
msgid   "This prompt explains the highlighted text in detail, ensuring clarity and understanding."
msgstr  "Dieser Prompt erklärt den hervorgehobenen Text ausführlich, um Klarheit und Verständnis zu gewährleisten."

#: ../assistant_prompts.lua:270
msgid   "Historical Context"
msgstr  "Historischer Kontext"

#: ../assistant_prompts.lua:273
msgid   "This prompt provides a detailed historical context for the highlighted text, explaining its significance and background."
msgstr  "Dieser Prompt liefert einen detaillierten historischen Kontext für den hervorgehobenen Text, erklärt seine Bedeutung und Hintergründe."

#: ../assistant_prompts.lua:285 ../main.lua:785
msgid   "Wikipedia"
msgstr  "Wikipedia"

#: ../assistant_prompts.lua:288
msgid   "This prompt generates a comprehensive Wikipedia-style article based on the highlighted text, ensuring factual accuracy and neutrality."
msgstr  "Dieser Prompt erzeugt einen umfassenden Wikipedia-ähnlichen Artikel basierend auf dem hervorgehobenen Text, wobei sachliche Genauigkeit und Neutralität sichergestellt werden."

